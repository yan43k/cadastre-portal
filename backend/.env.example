NODE_ENV=development
PORT=4001
DATABASE_URL="file:./dev.db"
JWT_ACCESS_SECRET="change-me-access-16chars-min"
JWT_REFRESH_SECRET="change-me-refresh-16chars"
ACCESS_TTL=15m
REFRESH_TTL_DAYS=14
CORS_ORIGINS=http://localhost:5174
FRONTEND_URL=http://localhost:5174
API_PUBLIC_URL=http://localhost:4001
COOKIE_SECURE=false
REFRESH_COOKIE_NAME=rt_cadastre
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=15
# PostgreSQL: DATABASE_URL="postgresql://user:pass@localhost:5432/cadastre?schema=public"
# SMTP optional
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=AdminPass123!
SEED_CLIENT_EMAIL=client@example.local
SEED_CLIENT_PASSWORD=ClientPass123!
