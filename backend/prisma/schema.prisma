// Кадастровый портал ИП — SQLite по умолчанию; для PostgreSQL: provider = "postgresql" и DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  role         String   @default("CLIENT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications     Application[]      @relation("UserApplications")
  notifications    Notification[]
  refreshSessions  RefreshSession[]
  appointments     Appointment[]
}

model RefreshSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Service {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  shortDesc     String?
  description   String
  stepsJson     String
  documentsJson String
  timelineNote  String?
  priceFromRub  Int?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Application {
  id            String    @id @default(cuid())
  publicNumber  String    @unique
  userId        String?
  serviceSlug   String?
  requestType   String
  status        String    @default("NEW")
  contactName   String
  contactEmail  String
  contactPhone  String?
  message       String?
  preferredDate String?
  priority      String    @default("NORMAL")
  internalNote  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user         User?                   @relation("UserApplications", fields: [userId], references: [id], onDelete: SetNull)
  attachments  ApplicationAttachment[]
  messages     ApplicationMessage[]

  @@index([userId])
  @@index([status])
}

model ApplicationAttachment {
  id            String   @id @default(cuid())
  applicationId String
  fileName      String
  storedPath    String
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ApplicationMessage {
  id            String   @id @default(cuid())
  applicationId String
  authorRole    String
  authorUserId  String?
  body          String
  readByClient  Boolean  @default(false)
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model OfficialDocument {
  id          String   @id @default(cuid())
  kind        String
  title       String
  description String?
  filePath    String?
  isPublic    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Qualification {
  id          String   @id @default(cuid())
  title       String
  org         String?
  year        Int?
  description String?
  sortOrder   Int      @default(0)
}

model News {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  summary     String?
  body        String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NormativeItem {
  id          String   @id @default(cuid())
  category    String
  title       String
  description String?
  externalUrl String?
  filePath    String?
  sortOrder   Int      @default(0)
}

model Appointment {
  id           String   @id @default(cuid())
  userId       String?
  startsAt     DateTime
  endsAt       DateTime
  status       String   @default("PENDING")
  contactName  String
  contactPhone String
  contactEmail String?
  notes        String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([startsAt])
}

model Review {
  id         String   @id @default(cuid())
  userId     String?
  authorName String
  rating     Int
  comment    String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Vacancy {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  requirements String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  applications VacancyApplication[]
}

model VacancyApplication {
  id        String   @id @default(cuid())
  vacancyId String
  name      String
  email     String
  phone     String?
  message   String?
  createdAt DateTime @default(now())

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@index([vacancyId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  payload   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PricingRule {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  meta      String?
  createdAt DateTime @default(now())
}
